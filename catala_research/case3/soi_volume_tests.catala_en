## Суммирование по типам — вклад даёт только целевой тип

Три помещения разных типов, объёмы `2 / 5 / 8`. Для холодной воды все три суммы
вычитаются с коэффициентом 1, поэтому `ΣV = 2 + 5 + 8 = 15`; `raw = 100 − 15 = 85`;
проверяем, что классификация суммирует именно все три категории.

```catala
#[test]
declaration scope TestClassificationSums:
  output house_soi content decimal
  s scope Soi_volume.MeteredColdSOI
scope TestClassificationSums:
  definition s.subject_norm_per_m2 equals 1.0
  definition s.v_house equals 100.0
  definition s.premises equals
    [ Soi_volume.Premise { -- volume: 2.0 -- area: 100.0 -- kind: Nonresidential } ;
      Soi_volume.Premise { -- volume: 5.0 -- area: 100.0 -- kind: ResidentialNoMeter } ;
      Soi_volume.Premise { -- volume: 8.0 -- area: 100.0 -- kind: ResidentialMetered } ]
  definition s.v_hot_selfproduced equals 0.0
  definition s.v_heating equals 0.0
  definition s.area_i equals 50.0
  definition s.area_common equals 1000.0
  definition s.persons equals 1000000
  definition s.days_in_period equals 30
  definition s.days_in_month equals 30
  definition house_soi equals s.house_soi
  assertion house_soi = 85.0
```
